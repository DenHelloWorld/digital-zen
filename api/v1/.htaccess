RewriteEngine On

# Security: Block access to sensitive files
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# CORS configuration for Chrome Extension
# ⚠️ PRODUCTION WARNING: Replace the hardcoded extension ID below with your actual extension ID
# The ID can be found at chrome://extensions/ (enable Developer mode)
# Current ID: hoefdaddakfckhgbciobghhjlehnfdge (replace this in production)
Header always set Access-Control-Allow-Origin "chrome-extension://hoefdaddakfckhgbciobghhjlehnfdge"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
Header always set Access-Control-Allow-Credentials "true"

# Handle preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route all other requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]