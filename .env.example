# Google OAuth Client ID (for Google authentication)
OAUTH_CLIENT_ID=your_google_oauth_client_id

# Chrome Extension Public Key (for Chrome Web Store)
PUBLIC_KEY=your_chrome_extension_public_key

# API Configuration
# API base URL (your hosting server)
API_URL=https://digital-zen.csmpoint.com/api

# API Secret Key (must match the key in api/config.php)
# Generate a strong random string (at least 32 characters)
# You can use https://randomkeygen.com/ to generate a secure key
# IMPORTANT: Use quotes if the key contains special characters like # or $
API_SECRET_KEY='your_random_secret_key_here'
