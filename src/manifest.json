{
  "manifest_version": 3,
  "name": "Digital Zen",
  "version": "1.0",
  "description": "Improve your focus by blocking distracting websites and managing focus sessions.",
  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "storage",
    "unlimitedStorage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "32": "icon-spa-transparent.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-spa-colored.png",
    "48": "icon-spa-colored.png",
    "128": "icon-spa-colored.png"
  }
}
