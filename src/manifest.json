{
  "manifest_version": 3,
  "name": "Digital Zen",
  "version": "1.0",
  "description": "An extension to improve focus and manage distracting websites.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs",
    "history"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
