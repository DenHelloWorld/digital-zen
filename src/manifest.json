{
  "manifest_version": 3,
  "name": "Digital Zen",
  "version": "1.0",
  "description": "An extension to improve focus and manage distracting websites.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs",
    "history"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "32": "icon-spa-transparent.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked-page.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
