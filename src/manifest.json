{
  "manifest_version": 3,
  "name": "Digital Zen",
  "version": "1.0",
  "description": "An extension to improve focus and manage distracting websites.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
