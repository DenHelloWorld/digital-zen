{
  "manifest_version": 3,
  "name": "Digital Zen",
  "version": "1.0",
  "description": "Improve your focus by blocking distracting websites and managing focus sessions.",
  "permissions": ["alarms", "declarativeNetRequest", "storage", "unlimitedStorage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["blocked-page.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "32": "icon-spa-transparent.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon-spa-colored.png",
    "48": "icon-spa-colored.png",
    "128": "icon-spa-colored.png"
  }
}
