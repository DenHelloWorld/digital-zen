{
  "name": "digital-zen-extension",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && tsc -p tsconfig.background.json && tsc-alias -p tsconfig.background.json",
    "build:prod": "ng build && tsc -p tsconfig.background.json && tsc-alias -p tsconfig.background.json && npm run patch-manifest",
    "patch-manifest": "dotenv -- node -e \"const fs=require('fs'); const m='./dist/browser/manifest.json'; const content=fs.readFileSync(m,'utf8'); fs.writeFileSync(m, content.replace('__OAUTH_CLIENT_ID__', process.env.OAUTH_CLIENT_ID));\"",    "watch": "concurrently \"ng build --watch --delete-output-path=false\" \"tsc -p tsconfig.background.json -w\" \"tsc-alias -w -p tsconfig.background.json\"",
    "test": "ng test",
    "lint": "ng lint",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint:fix": "ng lint --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/router": "^21.0.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.6",
    "@types/chrome": "^0.1.32",
    "angular-eslint": "21.1.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsc-alias": "^1.8.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.50.1"
  }
}
